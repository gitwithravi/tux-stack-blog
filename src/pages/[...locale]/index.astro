---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostList from '~/components/PostList.astro';
import Pagination from '~/components/Pagination.astro';
import { SITE } from '~/config';
import { localizedPath } from '~/i18n/utils';
import { getPosts } from '~/utils/posts';

export function getStaticPaths() {
  return SITE.locales.map((l) => ({
    params: { locale: l === SITE.defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}
const { locale } = Astro.props;

const posts = await getPosts(locale);
const pageSize = SITE.postsPerPage;
const lastPage = Math.max(1, Math.ceil(posts.length / pageSize));
const currentPage = 1;
const pagePosts = posts.slice(0, pageSize);

const hrefForPage = (n: number) => localizedPath(n === 1 ? '/' : `/page/${n}/`, locale);

// The homepage <title> is the site's most valuable SEO real estate:
// lead with the brand, then the core topics — no " — Site" suffix.
const homeTitle = `${SITE.title} — AI Systems, Engineering & Linux Deep-Dives`;
---

<BaseLayout
  title={homeTitle}
  absoluteTitle={true}
  description={SITE.description}
  pathWithoutLocale="/"
>
  {
    /* Visually-hidden H1: the homepage otherwise has no heading, and the
      sidebar site name is a <span>. Gives crawlers/AT a proper heading. */
  }
  <h1 class="sr-only">{homeTitle}</h1>
  <PostList posts={pagePosts} locale={locale} />
  <Pagination
    currentPage={currentPage}
    lastPage={lastPage}
    hrefForPage={hrefForPage}
    locale={locale}
  />
</BaseLayout>
