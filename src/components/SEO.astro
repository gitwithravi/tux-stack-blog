---
import { SITE } from '../config';
import { localizedPath, withBase } from '../i18n/utils';
import type { SeoMeta } from '../utils/seo';

interface Props {
  meta: SeoMeta;
}

const { meta } = Astro.props;

// Feed auto-discovery — feed readers and browser extensions look for
// these <link rel="alternate"> tags in <head>. We advertise the active
// locale's feed as the primary one, and (when multilingual) every other
// locale's feed too.
const primaryFeed = {
  href: new URL(localizedPath('/rss.xml', meta.locale), SITE.url).toString(),
  title: `${SITE.title} — RSS`,
};
const sitemapHref = new URL(withBase('/sitemap-index.xml'), SITE.url).toString();

// og:image:type from the file extension (png/svg/webp/jpeg).
const ogImagePath = meta.ogImage.split('?')[0].toLowerCase();
const ogImageType = ogImagePath.endsWith('.png')
  ? 'image/png'
  : ogImagePath.endsWith('.svg')
    ? 'image/svg+xml'
    : ogImagePath.endsWith('.webp')
      ? 'image/webp'
      : ogImagePath.endsWith('.jpg') || ogImagePath.endsWith('.jpeg')
        ? 'image/jpeg'
        : undefined;
const ogImageAlt = meta.ogImageAlt ?? meta.title;
---

<title>{meta.title}</title>
<meta name="description" content={meta.description} />
<link rel="canonical" href={meta.canonical} />
{
  /* max-image-preview:large keeps the 1200px OG images eligible for
    Google Discover / image surfaces. Exactly one robots meta is emitted. */
}
{
  meta.noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="max-image-preview:large" />
  )
}

{/* Feed + sitemap auto-discovery */}
<link
  rel="alternate"
  type="application/rss+xml"
  title={primaryFeed.title}
  href={primaryFeed.href}
/>
<link rel="sitemap" type="application/xml" href={sitemapHref} />

{/* Open Graph */}
<meta property="og:site_name" content={SITE.title} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:type" content={meta.type} />
<meta property="og:url" content={meta.canonical} />
<meta property="og:image" content={meta.ogImage} />
{ogImageType && <meta property="og:image:type" content={ogImageType} />}
{meta.ogImageWidth && <meta property="og:image:width" content={String(meta.ogImageWidth)} />}
{meta.ogImageHeight && <meta property="og:image:height" content={String(meta.ogImageHeight)} />}
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content={meta.ogLocale} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={meta.ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{/* Article-specific */}
{
  meta.type === 'article' && meta.publishedTime && (
    <meta property="article:published_time" content={meta.publishedTime} />
  )
}
{
  meta.type === 'article' && meta.modifiedTime && (
    <meta property="article:modified_time" content={meta.modifiedTime} />
  )
}
{meta.type === 'article' && <meta property="article:author" content={SITE.author.name} />}
{meta.type === 'article' && meta.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

{/* hreflang alternates for SEO */}
{
  SITE.multilingual &&
    meta.hreflangs.map(({ locale, href }) => <link rel="alternate" hreflang={locale} href={href} />)
}

<script is:inline type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />
